# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL (or any PostgreSQL >= 14)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Admin ─────────────────────────────────────────────────────────────────────
# Random hex string — required to create API keys via POST /v1/admin/keys
ADMIN_KEY=change_me_to_a_random_64_char_hex

# ── Oracle signing key (ed25519) ───────────────────────────────────────────────
# Generate once:  node -e "const c=require('crypto'); const {privateKey}=c.generateKeyPairSync('ed25519'); console.log(privateKey.export({type:'pkcs8',format:'der'}).toString('base64'));"
# If unset: ephemeral key is generated on startup (not suitable for production)
ORACLE_PRIVATE_KEY=

# ── OPNet RPC upstream (for /v1/rpc proxy) ────────────────────────────────────
OPNET_RPC_URL=https://testnet.opnet.org/api/v1/json-rpc
